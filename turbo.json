{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "db:generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["@orbetra/db#db:generate", "^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["@orbetra/db#db:generate"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["@orbetra/db#db:generate"]
    }
  }
}
