{
  "name": "orbetra",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts/githooks || true",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "gates": "turbo run typecheck lint test"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.30.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
