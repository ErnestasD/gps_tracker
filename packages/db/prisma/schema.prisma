// Orbetra relational schema (E01-3). PROJECT_PLAN §6.3.
// `positions` is deliberately NOT here — hypertable lives in packages/db/sql/ and is
// raw-SQL-only territory (CLAUDE.md rule 1, ADR-003 boundary).
// Column design derived from spec references; see docs/epics/E01-3-plan.md ambiguity note.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  platform_admin
  tsp_admin
  account_manager
  viewer
}

enum CommandStatus {
  queued
  sent
  acked
  failed
  expired
}

enum TripStatus {
  open
  closed
}

enum GeofenceKind {
  polygon
  circle
  corridor
}

enum RuleKind {
  geofence
  overspeed
  ignition
  din_change
  power_cut
  low_battery
  panic
  device_offline
}

enum OdometerSource {
  auto
  device
  gps
}

model Tenant {
  id                     String   @id @default(uuid()) @db.Uuid
  name                   String
  /// white-label: { logoUrl, primary, accent, productName, supportEmail } (E03-5)
  branding               Json     @default("{}")
  /// set once from pilot-lead ref, immutable afterwards (§6.9)
  referredByAffiliateId  String?  @db.Uuid
  /// Stripe billing (ADR-024). Set lazily on first checkout; subscription state is written
  /// ONLY by the signature-verified webhook, never by the browser.
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?
  /// mirrors Stripe's subscription.status (active|trialing|past_due|canceled|unpaid|…); null = never subscribed
  subscriptionStatus     String?
  currentPeriodEnd       DateTime? @db.Timestamptz()
  /// timestamp of the last APPLIED Stripe event; a webhook update lands only when strictly newer
  /// (monotonic guard against out-of-order/duplicate delivery — ADR-024)
  lastBillingEventAt     DateTime? @db.Timestamptz()
  createdAt              DateTime @default(now()) @db.Timestamptz()

  accounts Account[]
  users    User[]
  domains  TenantDomain[]

  @@map("tenants")
}

model TenantDomain {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  domain    String
  /// true after the DNS TXT verification job; Caddy ask endpoint checks this (E03-5)
  verified  Boolean  @default(false)
  txtToken  String
  createdAt DateTime @default(now()) @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Global uniqueness applies ONLY to VERIFIED domains — enforced by a partial unique
  // index added in migration SQL (Prisma can't express `WHERE verified`). First tenant
  // to prove DNS ownership wins; a pending squat can't block the real owner from
  // adding+verifying. Pending rows are unique per tenant only (composite below).
  @@unique([tenantId, domain])
  @@index([tenantId])
  @@map("tenant_domains")
}

model Account {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  /// IANA zone; ALL rendering converts from UTC with this (CLAUDE.md rule 7)
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @db.Timestamptz()

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users   User[]
  devices Device[]

  @@index([tenantId])
  @@map("accounts")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  /// null ⇒ tenant-level user (tsp_admin); set ⇒ scoped to one account
  accountId    String?  @db.Uuid
  email        String
  passwordHash String
  role         Role
  locale       String   @default("en")
  createdAt    DateTime @default(now()) @db.Timestamptz()

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([accountId])
  /// login is cross-tenant (email may exist in N tenants) — the composite unique
  /// can't serve an email-only lookup, so index email alone (E03-1, review LOW)
  @@index([email])
  @@map("users")
}

/// Rotating refresh-token families (E03-1, §6.6): raw token = 32B CSPRNG, only its
/// sha256 stored (deterministic unique lookup; 256-bit entropy makes offline brute
/// force moot — same rationale as ApiKey.hash). familyId = id of the family's first
/// token; reuse of a rotated token revokes the whole family.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  familyId  String    @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz()
  createdAt DateTime  @default(now()) @db.Timestamptz()
  /// set when consumed to mint a successor (rotation)
  rotatedAt DateTime? @db.Timestamptz()
  /// set by logout / family revocation on reuse detection
  revokedAt DateTime? @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
  @@map("refresh_tokens")
}

model DeviceProfile {
  id             String @id @default(uuid()) @db.Uuid
  /// seed keys: fmb1xx, fmc, fmb6xx-stub, tat-asset (E03-3)
  key            String @unique
  name           String
  /// trip/presence thresholds (§6.4); offline sweeper reads these (§6.5)
  presenceRules  Json   @default("{}")
  commandPresets Json   @default("[]")
  /// ingest read-idle timeout, minutes (§6.1 top)
  readIdleMin    Int    @default(40)

  devices Device[]

  @@map("device_profiles")
}

model Device {
  id             BigInt          @id @default(autoincrement())
  tenantId       String          @db.Uuid
  accountId      String          @db.Uuid
  profileId      String          @db.Uuid
  /// 15-digit string — leading zeros preserved (E03-3 edge case)
  imei           String          @unique
  name           String
  plate          String?
  groupName      String?
  odometerSource OdometerSource  @default(auto)
  retiredAt      DateTime?       @db.Timestamptz()
  createdAt      DateTime        @default(now()) @db.Timestamptz()

  account Account       @relation(fields: [accountId], references: [id])
  profile DeviceProfile @relation(fields: [profileId], references: [id])
  shareLinks ShareLink[]
  maintenanceItems MaintenanceItem[]

  @@index([tenantId, accountId])
  @@map("devices")
}

/// Temporary public share link (V1-nice) — an expiring, revocable URL exposing ONE device's
/// live position with no login. Token stored as SHA-256 hash + short prefix (like ApiKey,
/// E06-3); plaintext returned once. Expiry + revoke are enforced in the resolve query.
model ShareLink {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  /// copied from the device at creation so account-scoped users see only their own links
  accountId       String    @db.Uuid
  deviceId        BigInt
  /// SHA-256 of the opaque token — the plaintext is never stored
  tokenHash       String    @unique
  /// short display prefix (first chars) for the management list
  tokenPrefix     String
  label           String?
  createdByUserId String    @db.Uuid
  expiresAt       DateTime  @db.Timestamptz()
  revokedAt       DateTime? @db.Timestamptz()
  createdAt       DateTime  @default(now()) @db.Timestamptz()

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deviceId])
  @@map("share_links")
}

/// Driver registry (V2). Account-scoped. `ibutton` is the driver's physical iButton/RFID key id
/// (hex) — stored so a follow-up can resolve a tap (AVL iButton) to a driver and stamp the trip.
/// iButton is unique WITHIN a tenant (NULLs are distinct in Postgres → many keyless drivers ok).
model Driver {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  accountId String   @db.Uuid
  name      String
  licenseNo String?
  ibutton   String?
  phone     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  trips Trip[]

  @@unique([tenantId, ibutton])
  @@index([tenantId, accountId])
  @@map("drivers")
}

/// Maintenance schedule item (V2). Per-device service reminder by odometer km and/or elapsed days.
/// Due is computed at READ time from the device's current odometer + now (not stored). Account-scoped.
model MaintenanceItem {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  accountId        String    @db.Uuid
  deviceId         BigInt
  title            String
  intervalKm       Int?
  intervalDays     Int?
  lastServiceOdoKm Int?
  lastServiceAt    DateTime? @db.Timestamptz()
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @db.Timestamptz()

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, accountId])
  @@index([deviceId])
  @@map("maintenance_items")
}

model RawReject {
  id        BigInt   @id @default(autoincrement())
  imei      String?
  reason    String
  payload   Bytes?
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([createdAt])
  @@map("raw_rejects")
}

model Trip {
  id             BigInt     @id @default(autoincrement())
  tenantId       String     @db.Uuid
  accountId      String     @db.Uuid
  deviceId       BigInt
  status         TripStatus
  startTime      DateTime   @db.Timestamptz()
  endTime        DateTime?  @db.Timestamptz()
  startLat       Float?
  startLon       Float?
  endLat         Float?
  endLon         Float?
  distanceM      Int        @default(0)
  /// 'odometer' | 'gps' — surfaced in UI/reports (E04-5)
  distanceSource String     @default("gps")
  maxSpeed       Int        @default(0)
  idleS          Int        @default(0)
  /// driver on this trip (V2) — assigned manually or resolved from the iButton tap (follow-up).
  /// SET NULL on driver delete so trip history survives (never a dangling FK).
  driverId       String?    @db.Uuid
  createdAt      DateTime   @default(now()) @db.Timestamptz()

  driver Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([deviceId, startTime])
  @@index([tenantId, accountId, startTime])
  @@map("trips")
}

model Geofence {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  /// null ⇒ visible to all accounts of the tenant (E05-1 accounts scope)
  accountId String?      @db.Uuid
  name      String
  color     String       @default("#4DA3FF")
  kind      GeofenceKind
  /// raw accessors only (ST_GeomFromGeoJSON etc, E05-1); area guard ≤ 10,000 km²
  geom      Unsupported("geography(Polygon,4326)")
  createdAt DateTime     @default(now()) @db.Timestamptz()

  @@index([tenantId, accountId])
  @@map("geofences")
}

model Rule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  accountId String   @db.Uuid
  kind      RuleKind
  name      String
  /// kind-specific config: thresholds, geofenceId, …
  config    Json     @default("{}")
  /// device/group scope selector (E05-3)
  scope     Json     @default("{}")
  /// notification channels: email/telegram/webhook refs (E05-4)
  channels  Json     @default("[]")
  cooldownS Int      @default(300)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([tenantId, accountId, enabled])
  @@map("rules")
}

model Event {
  id             BigInt    @id @default(autoincrement())
  tenantId       String    @db.Uuid
  accountId      String    @db.Uuid
  deviceId       BigInt
  ruleId         String?   @db.Uuid
  kind           String
  at             DateTime  @db.Timestamptz()
  lat            Float?
  lon            Float?
  payload        Json      @default("{}")
  acknowledgedAt DateTime? @db.Timestamptz()
  createdAt      DateTime  @default(now()) @db.Timestamptz()

  @@index([tenantId, accountId, at])
  @@index([deviceId, at])
  @@map("events")
}

model Command {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @db.Uuid
  accountId String        @db.Uuid
  deviceId  BigInt
  text      String
  status    CommandStatus @default(queued)
  response  String?
  createdAt DateTime      @default(now()) @db.Timestamptz()
  sentAt    DateTime?     @db.Timestamptz()
  /// §3.5: expire after 24 h
  expiresAt DateTime      @db.Timestamptz()

  @@index([deviceId, status])
  @@index([tenantId, accountId, createdAt])
  @@map("commands")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  accountId  String?   @db.Uuid
  name       String
  /// orb_live_<8 chars> shown in UI; full key never stored (E06-3)
  prefix     String
  /// SHA-256 of the full key
  hash       String    @unique
  scopes     String[]  @default(["read"])
  lastUsedAt DateTime? @db.Timestamptz()
  revokedAt  DateTime? @db.Timestamptz()
  createdAt  DateTime  @default(now()) @db.Timestamptz()

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  accountId String?  @db.Uuid
  url       String
  /// HMAC-SHA256 signing secret (§6.5); rotation = new row + 24 h dual-sign (E06-4)
  secret    String
  events    String[] @default([])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([tenantId, enabled])
  @@map("webhooks")
}

/// Webhook delivery attempts (E06-4b) — one row per POST attempt for observability/debugging.
/// Written by the worker (raw SQL); read-only over the API. Retention pruning is W7.
model WebhookDelivery {
  id         BigInt   @id @default(autoincrement())
  tenantId   String   @db.Uuid
  accountId  String?  @db.Uuid
  webhookId  String   @db.Uuid
  eventId    String
  kind       String
  /// HTTP status if a response arrived; null on a network error / timeout / blocked URL
  statusCode Int?
  success    Boolean
  /// short failure reason (never the payload/secret)
  error      String?
  at         DateTime @default(now()) @db.Timestamptz()

  @@index([tenantId, at])
  @@index([webhookId, at])
  @@map("webhook_deliveries")
}

/// GDPR account data export job (E08-4). File lands in EXPORT_DIR; download is scoped +
/// expires (410 after expiresAt). R2/S3 upload is a follow-up when creds exist.
model ExportJob {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  accountId String    @db.Uuid
  status    String    @default("pending") // pending | done | failed
  /// absolute path of the .json.gz once done (never exposed to clients)
  path      String?
  sizeBytes BigInt?
  error     String?
  createdAt DateTime  @default(now()) @db.Timestamptz()
  expiresAt DateTime  @db.Timestamptz()

  @@index([tenantId, createdAt])
  @@map("export_jobs")
}

/// Pilot-request lead from the public site (W9-S1, §6.9). UNSCOPED table — leads
/// precede tenants; readable by platform_admin only.
model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  company     String
  email       String
  phone       String?
  deviceCount String?
  message     String?
  /// affiliate code from the tc_ref cookie (§6.9 last-touch)
  ref         String?
  createdAt   DateTime @default(now()) @db.Timestamptz()

  @@index([createdAt])
  @@map("leads")
}

model UsageDaily {
  tenantId  String   @db.Uuid
  accountId String   @db.Uuid
  deviceId  BigInt
  day       DateTime @db.Date
  active    Boolean  @default(true)

  @@id([deviceId, day])
  @@index([tenantId, day])
  @@map("usage_daily")
}

model AuditLog {
  id       BigInt   @id @default(autoincrement())
  tenantId String?  @db.Uuid
  userId   String?  @db.Uuid
  action   String
  entity   String
  entityId String
  before   Json?
  after    Json?
  at       DateTime @default(now()) @db.Timestamptz()

  @@index([tenantId, at])
  @@map("audit_log")
}

model GeocodeCache {
  /// geohash7 ≈ 150 m cell (§6.3)
  gridKey    String   @id
  address    String
  resolvedAt DateTime @default(now()) @db.Timestamptz()

  @@map("geocode_cache")
}
