{
  "title": "Orbetra Ingest Pipeline",
  "uid": "orbetra-ingest",
  "timezone": "utc",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Ingest rate (msg/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(ingest_msgs_total[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "ACK latency p99 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(ack_latency_ms_bucket[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Stream depth per shard",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "stream_depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline lag p95 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "quantile_over_time(0.95, pipeline_lag_ms[5m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Parse failures & frame violations (/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(ingest_parse_fail_total[5m])",
          "refId": "A",
          "legendFormat": "parse fail"
        },
        {
          "expr": "rate(ingest_frame_violations_total[5m])",
          "refId": "B",
          "legendFormat": "frame violations"
        }
      ]
    },
    {
      "id": 6,
      "title": "Paused sockets (I4 backpressure)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ingest_paused_sockets",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Batch rows p50/p95",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(pipeline_batch_rows_bucket[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "WS clients",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ws_clients",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
