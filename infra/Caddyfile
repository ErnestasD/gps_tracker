# Orbetra reverse proxy (E01-2, E03-5). Tenant custom domains get automatic HTTPS
# via on-demand TLS: Caddy asks the api before minting a cert, so a cert is only
# ever issued for a domain a tenant has verified (DNS TXT). An unreachable ask
# endpoint = deny, so a broken api never leaks certs for arbitrary hostnames.
{
	on_demand_tls {
		ask http://api:3010/v1/internal/caddy-ask
		# the api rate-limits ask per source IP; keep Caddy's own interval modest
		interval 2m
		burst 5
	}
}

# Local/dev default: plain HTTP on :80 with health endpoint.
:80 {
	respond /healthz "ok" 200
	# app routes are wired in E02+ stories (api, web); keep 404 for everything else
	respond 404
}

# ── Tenant custom domains (staging/prod) ─────────────────────────────────────
# Any hostname NOT matched above gets a cert on demand (gated by the ask above),
# then proxies to web (SPA) with /v1 + /ws carved out to the api. The SPA reads
# GET /v1/branding (Host-based) for the pre-login logo/colors. Enable by setting
# ORBETRA_PUBLIC=true in the compose env; left off locally (no :443, no real DNS).
# NOTE: requires `api` and `web` services reachable on this network — present in
# the staging compose overlay, absent in the local infra-only compose.
https:// {
	tls {
		on_demand
	}
	# Security headers at the edge (E07-5). Site-wide, so /v1 responses carry them TWICE
	# (edge + the api's own set — defense in depth). Duplicates are harmless while the two
	# layers stay IDENTICAL; if you change a value here, change apps/api/src/security.ts
	# too (conflicting XFO/STS duplicates confuse browsers). The SPA is never embedded,
	# so framing is denied outright.
	header {
		Strict-Transport-Security "max-age=15552000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}
	# API + realtime first (longest-prefix wins in Caddy route ordering)
	handle /v1/* {
		reverse_proxy api:3010
	}
	handle /ws {
		reverse_proxy api:3010
	}
	# everything else is the SPA
	handle {
		reverse_proxy web:5173
	}
}
